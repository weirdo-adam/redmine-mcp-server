{
  "name": "redmine-mcp-server",
  "version": "0.1.1",
  "description": "Standalone stdio MCP server for Redmine.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weirdo-adam/redmine-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "redmine",
    "stdio",
    "model-context-protocol"
  ],
  "bin": {
    "redmine-mcp-server": "server/index.js"
  },
  "scripts": {
    "check": "scripts/check.sh",
    "install:local": "scripts/install-local.sh",
    "lint": "npm run lint:js",
    "lint:js": "node --check server/index.js && node --check server/src/redmine.js && node --check server/src/tools.js && node --check test/redmine.test.js",
    "package:release": "scripts/package-release.sh",
    "start": "node server/index.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18.17"
  }
}
